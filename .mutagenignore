# Mutagen ignore policy reviewed 2026-05-27.
# Sync source, configs, docs, tests, and small research context.
# Do not sync local market data, generated results, logs, caches, or secrets.

# Large/local data and generated outputs
# Anchored to the sync root with a leading slash so it only ignores the top-level
# market-data store, NOT source packages named "data" (src/autotrade/environment/data/,
# scripts/data/), which must stay synced for the file tools.
/data/
/raw_data/
/results/
/reports/
/artifacts/
/wandb/
/mlruns/
/logs/
/.runtime/
/archive/
/external_references/
/experiments/

# Python/runtime caches and local environments
.venv/
venv/
env/
.conda/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.coverage
htmlcov/
*.pyc
*.pyo
*.egg-info/

# Secrets and local editor state
.env
.env.local
.env.*.local
config/local.env
config/*.local.env
.vscode/
.idea/

# Large binary/model/data files
*.h5
*.hdf5
*.pkl
*.pickle
*.pt
*.pth
*.ckpt
*.safetensors
*.npy
*.npz
*.parquet
*.feather
*.arrow
*.csv

# Runtime/system noise
*.log
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.ai-remote-project.env

# Re-include source packages literally named "data". The broad unanchored "data/"
# ignore (both in the global Mutagen config and the rule above) would otherwise mask
# these source dirs from the file tools; negations are applied last and override it.
# These dirs hold only .py source (no parquet/csv), so nothing large is re-synced.
!src/autotrade/environment/data/
!scripts/data/
