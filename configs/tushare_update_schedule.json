{
  "schema_version": 1,
  "source_verified_at": "2026-05-29",
  "timezone": "Asia/Shanghai",
  "repo_root": "/Data/lzp/MacroQuant",
  "python": "/home/lzp/miniconda3/envs/quant/bin/python",
  "default_start_date": "20200101",
  "default_raw_dir": "data/raw",
  "default_pit_root": "data/pit",
  "default_lock_wait_seconds": 900,
  "default_update_args": [
    "--min-interval-seconds",
    "0.22",
    "--timeout-seconds",
    "120"
  ],
  "revision_monitor": {
    "ledger_path": "results/data_quality/revision_events.jsonl",
    "summary_path": "results/data_quality/revision_summary.json",
    "sentinel_datasets": ["daily", "adj_factor", "daily_basic", "stk_limit", "suspend_d", "limit_list_d"],
    "sentinel_sample_size": 12
  },
  "jobs": {
    "cn_evening_full": {
      "description": "Run one rolling-window retained-domain update after normal A-share, minute, flow, block-trade, text, and macro same-day releases should be available.",
      "end_date_offset_days": 0,
      "end_date_mode": "sse_open_on_or_before",
      "start_date_lookback_days": 30,
      "extra_args": [
        "--reference-min-interval-seconds",
        "0.50",
        "--refresh-open-window",
        "--intraday-refresh-lookback-days",
        "1",
        "--refresh-reference-datasets",
        "stock_basic",
        "stock_company",
        "bak_basic",
        "namechange",
        "index_classify",
        "index_member_all",
        "ths_index",
        "index_basic",
        "--refresh-daily-datasets",
        "daily",
        "adj_factor",
        "daily_basic",
        "stk_limit",
        "suspend_d",
        "limit_list_d",
        "stk_auction",
        "--fundamental-refresh-period-count",
        "6",
        "--fundamental-refresh-ann-month-count",
        "3",
        "--fundamental-refresh-ts-code-datasets",
        "dividend",
        "fina_audit",
        "fina_mainbz_vip",
        "--fundamental-refresh-event-days",
        "90",
        "--fundamental-dividend-probe-days",
        "90",
        "--event-datasets",
        "margin_secs",
        "moneyflow",
        "moneyflow_dc",
        "moneyflow_ths",
        "moneyflow_ind_dc",
        "moneyflow_ind_ths",
        "moneyflow_cnt_ths",
        "cyq_perf",
        "bak_daily",
        "stk_premarket",
        "slb_len",
        "slb_len_mm",
        "top10_holders",
        "top10_floatholders",
        "pledge_detail",
        "stk_surv",
        "new_share",
        "stk_holdernumber",
        "stk_holdertrade",
        "repurchase",
        "block_trade"
      ],
      "skip_if_already_ok": true
    },
    "cn_nightly_full_audit": {
      "description": "Refresh the six formal data-quality status files over the full retained research window after the evening update.",
      "operation": "audit_full",
      "end_date_offset_days": 1,
      "event_flow_end_date_mode": "sse_open_on_or_before",
      "fail_fast": false,
      "skip_if_already_ok": true
    },
    "cn_daily_revision_sentinel": {
      "description": "Sample historical daily trade-date partitions, compare TuShare source responses with local raw files without overwriting raw data, and append revision events when differences are found. Sample size and datasets come from revision_monitor.sentinel_* (single source).",
      "operation": "revision_sentinel",
      "end_date_offset_days": 1,
      "end_date_mode": "sse_open_on_or_before",
      "extra_args": [],
      "lock_wait_seconds": 1800,
      "skip_if_already_ok": true
    },
    "cn_nightly_pit_event_build": {
      "description": "Build and audit PIT-ready financial event availability partitions for snapshot construction.",
      "operation": "pit_event_pipeline",
      "end_date_offset_days": 1,
      "start_date_lookback_days": 120,
      "fundamental_events_root": "data/pit/fundamental_events",
      "fundamental_events_status": "results/data_quality/fundamental_events_status.json",
      "lock_wait_seconds": 1800,
      "skip_if_already_ok": true
    },
    "cn_preopen_board_backfill_0850": {
      "description": "Pre-open targeted refresh for previous-day board-trading sources that publish after the prior evening window, especially kpl_list next-day 08:30 data.",
      "operation": "download_tier",
      "tier": "board_trading",
      "end_date_offset_days": 1,
      "end_date_mode": "sse_open_on_or_before",
      "start_date_lookback_days": 0,
      "extra_args": [
        "--datasets",
        "kpl_list",
        "limit_step",
        "limit_cpt_list",
        "--force"
      ],
      "lock_wait_seconds": 180,
      "skip_if_already_ok": true
    },
    "cn_preopen_text_backfill_0855": {
      "description": "Pre-open short text refresh for the previous natural days where cctv_news/news may not have been complete during the prior evening window.",
      "operation": "download_tier",
      "tier": "text_evidence",
      "end_date_offset_days": 1,
      "start_date_lookback_days": 2,
      "extra_args": [
        "--datasets",
        "cctv_news",
        "news",
        "--force"
      ],
      "lock_wait_seconds": 180,
      "skip_if_already_ok": true
    },
    "cn_preopen_margin_backfill_0905": {
      "description": "Pre-open targeted first attempt for previous-day margin data. Keep it light so downstream audit, snapshot freeze, and Agent decisions can finish before 09:25.",
      "operation": "download_event_flow",
      "end_date_offset_days": 1,
      "end_date_mode": "sse_open_on_or_before",
      "extra_args": [
        "--datasets",
        "margin",
        "margin_detail",
        "--force"
      ],
      "lock_wait_seconds": 180,
      "skip_if_already_ok": true
    },
    "cn_preopen_margin_secs_backfill_0903": {
      "description": "Pre-open first attempt for same-day financing/margin eligibility before Agent decisions.",
      "operation": "download_event_flow",
      "end_date_offset_days": 0,
      "end_date_mode": "sse_open_on_or_before",
      "extra_args": [
        "--datasets",
        "margin_secs",
        "--force"
      ],
      "lock_wait_seconds": 180,
      "skip_if_already_ok": true
    },
    "cn_preopen_margin_retry_0915": {
      "description": "Pre-open targeted retry for previous-day margin data. It uses a distinct job name so it still runs if the 09:05 source response was empty but returned successfully.",
      "operation": "download_event_flow",
      "end_date_offset_days": 1,
      "end_date_mode": "sse_open_on_or_before",
      "extra_args": [
        "--datasets",
        "margin",
        "margin_detail",
        "--force"
      ],
      "lock_wait_seconds": 180,
      "skip_if_already_ok": true
    },
    "cn_preopen_margin_secs_retry_0913": {
      "description": "Pre-open retry for same-day financing/margin eligibility before Agent decisions.",
      "operation": "download_event_flow",
      "end_date_offset_days": 0,
      "end_date_mode": "sse_open_on_or_before",
      "extra_args": [
        "--datasets",
        "margin_secs",
        "--force"
      ],
      "lock_wait_seconds": 180,
      "skip_if_already_ok": true
    },
    "cn_preopen_event_flow_audit_0920": {
      "description": "Refresh previous-day margin status after the pre-open margin retry so 09:25 gates do not use stale T+1 margin coverage.",
      "operation": "audit_event_flow",
      "end_date_offset_days": 1,
      "end_date_mode": "sse_open_on_or_before",
      "lock_wait_seconds": 240,
      "skip_if_already_ok": true
    }
  },
