# The sandbox image build context is the repo root only so the Dockerfile can COPY
# the single trusted runtime module (src/autotrade/environment/replay/driver.py).
# Exclude the large data/runtime/vendored trees so the context stays small and fast.
.git
data
datasets
results
reports
wandb
mlruns
archive
raw_data
artifacts
experiments
logs
.runtime
external_references
.mypy_cache
.pytest_cache
.ruff_cache
**/__pycache__
*.pyc
*.pyo
.venv
.conda
node_modules
